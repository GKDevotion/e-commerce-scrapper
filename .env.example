APP_NAME="Amazon Listing Builder"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Kolkata

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=amazon_listing_builder
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000

CACHE_STORE=redis
CACHE_PREFIX=alb_

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@amazonlistingbuilder.com"
MAIL_FROM_NAME="${APP_NAME}"

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-4o
#gpt-5
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# Amazon SP-API
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_SP_API_REFRESH_TOKEN=
AMAZON_SP_API_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_SP_API_REGION=us-east-1
AMAZON_SP_API_AWS_ACCESS_KEY=
AMAZON_SP_API_AWS_SECRET_KEY=
AMAZON_SP_API_ROLE_ARN=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Scraper Settings
SCRAPER_TIMEOUT=30
SCRAPER_RETRY_TIMES=3
SCRAPER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# Rate Limiting
RATE_LIMIT_API=60
RATE_LIMIT_SCRAPER=10
RATE_LIMIT_AI=20

# Subscription Limits
FREE_LISTINGS_LIMIT=5
STARTER_LISTINGS_LIMIT=50
PRO_LISTINGS_LIMIT=200
ENTERPRISE_LISTINGS_LIMIT=-1

# Admin
ADMIN_EMAIL=admin@amazonlistingbuilder.com

VITE_APP_NAME="${APP_NAME}"
